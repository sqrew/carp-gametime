(load "Test.carp")
(use Test)
(load "gametime.carp")
(use Clock)

(deftest gametime-test
  (let [c (Clock.new)
        s0 (Test.State.init 0 0)
        s1 (assert-equal &s0 1.0 (Clock.scale &c) "Initial scale is 1.0")
        s2 (assert-equal &s1 0.0 (Clock.total &c) "Initial total is 0.0")
        s3 (assert-equal &s1 0.0 (Clock.real-total &c) "Initial real-total is 0.0")
        s4 (assert-equal &s3 0.0 (Clock.unscaled-dt &c) "Initial dt is 0.0")]
    (do
      ;; Tick 1: Normal advancement
      (System.sleep-micros 10000) ;; Sleep 10ms
      (Clock.tick! &c)
      (let [dt1 (Clock.unscaled-dt &c)
            total1 (Clock.total &c)
            rtotal1 (Clock.real-total &c)
            s5 (assert-true &s4 (> dt1 0.0) "dt is positive after sleep")
            s6 (assert-true &s5 (Generics.approx dt1 total1) "Total approx equals dt after first tick")
            s7 (assert-true &s6 (Generics.approx total1 rtotal1) "Total equals real-total when no clamping occurs")]
        (do
          ;; Tick 2: Scaling
          (Clock.set-scale! &c 0.5)
          (System.sleep-micros 10000)
          (Clock.tick! &c)
          (let [dt2 (Clock.unscaled-dt &c)
                sdt2 (Clock.scaled-dt &c)
                total2 (Clock.total &c)
                s8 (assert-true &s7 (Generics.approx (* dt2 0.5) sdt2) "scaled-dt respects scale")
                s9 (assert-true &s8 (> total2 total1) "Total increases monotonically")]
            (do
              ;; Tick 3: Clamping (Divergence test)
              (Clock.set-max-dt! &c 0.01) ;; Clamp to 10ms
              (System.sleep-micros 50000) ;; Wait 50ms (Actual dt should be ~50ms)
              (Clock.tick! &c)
              (let [dt3 (Clock.unscaled-dt &c)
                    total3 (Clock.total &c)
                    rtotal3 (Clock.real-total &c)
                    s10 (assert-true &s9 (<= dt3 0.0101) "dt is clamped by max-dt")
                    s11 (assert-true &s10 (> rtotal3 total3) "real-total diverges from simulation total during clamping")]
                (do
                  ;; Tick 4: Pause logic
                  (Clock.pause! &c)
                  (System.sleep-micros 10000)
                  (Clock.tick! &c)
                  (let [sdt4 (Clock.scaled-dt &c)
                        dt4 (Clock.unscaled-dt &c)
                        s12 (assert-equal &s11 0.0 sdt4 "scaled-dt is 0.0 when paused")
                        s13 (assert-true &s12 (> dt4 0.0) "unscaled-dt still advances when paused")]
                    (do
                      ;; Reset
                      (Clock.reset! &c)
                      (assert-equal &s13 0.0 (Clock.unscaled-dt &c) "dt is 0.0 after reset"))))))))))))
